{
  "name": "高级多维监控",
  "description": "监控多个指标的阈值和变化率",

  "schedule": "every 1 hours",

  "monitors": [
    {
      "name": "GMV综合监控",
      "card_id": "card_gmv",
      "metric_field": "gmv_amount",
      "filters": [
        {
          "filterType": "common",
          "filterInfo": {
            "name": "日期",
            "fdId": "date_dim",
            "conditionType": "EQ",
            "filterValues": ["今天"]
          }
        }
      ],
      "rules": [
        {
          "type": "threshold",
          "operator": "lt",
          "threshold": 5000000,
          "alert_level": "warning",
          "message": "GMV低于500万"
        },
        {
          "type": "change_rate",
          "compare_with": "yesterday",
          "operator": "lt",
          "threshold": -0.15,
          "alert_level": "critical",
          "message": "GMV环比昨天下降超过15%"
        },
        {
          "type": "change_rate",
          "compare_with": "last_week",
          "operator": "lt",
          "threshold": -0.2,
          "alert_level": "critical",
          "message": "GMV同比上周下降超过20%"
        }
      ]
    },
    {
      "name": "转化率监控",
      "card_id": "card_conversion",
      "metric_field": "conversion_rate",
      "rules": [
        {
          "type": "range",
          "min_value": 0.05,
          "max_value": 0.20,
          "alert_level": "warning",
          "message": "转化率超出正常区间[5%, 20%]"
        }
      ]
    }
  ],

  "notification": {
    "template_code": "DING_DEFAULT_ALERT",
    "biz_type": "common",
    "recipients": ["user_1", "user_2", "user_3"]
  }
}
